# ═══════════════════════════════════════════════════════════════════════
# 闪象 (ShanXiang) — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# 复制此文件为 .env 并填入实际值。
# 标记 [REQUIRED] 的变量在生产和本地都必须设置，缺失会导致启动失败。
# 标记 [PRODUCTION] 的变量在本地开发可选，但生产环境必须设置。

# ── Database (PostgreSQL) ──────────────────────────────────────────────

# [REQUIRED] PostgreSQL 连接字符串，使用 @prisma/adapter-pg 直连
# 本地: postgresql://user:pass@localhost:5432/shanxiang
# Vercel 推荐 Neon: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/shanxiang?sslmode=require
DATABASE_URL=

# ── NextAuth v5 (Authentication) ───────────────────────────────────────

# [REQUIRED] 加密 JWT session 的密钥，用 `openssl rand -hex 32` 生成
AUTH_SECRET=

# [PRODUCTION] Google OAuth 凭证，从 https://console.cloud.google.com/apis/credentials 获取
# 本地开发可用 demo@shanxiang.ai / demo123 的 Credentials 登录
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# [PRODUCTION] NextAuth 回调基础 URL，一般为 https://yourdomain.com
# Vercel 部署时设为 https://your-project.vercel.app
# 本地默认 http://localhost:3000
NEXTAUTH_URL=

# ── AI Generation (Replicate) ──────────────────────────────────────────

# [REQUIRED] 从 https://replicate.com/account/api-tokens 获取
REPLICATE_API_KEY=

# [Optional] 模型版本，默认 black-forest-labs/flux-schnell
# REPLICATE_MODEL_VERSION=black-forest-labs/flux-schnell

# [Optional] Replicate webhook URL，用于异步接收生图结果
# REPLICATE_WEBHOOK_URL=https://yourdomain.com/api/webhooks/replicate

# ── Stripe (Billing) ───────────────────────────────────────────────────

# [PRODUCTION] Stripe Secret Key，从 https://dashboard.stripe.com/apikeys 获取
# 开发测试用 sk_test_，生产用 sk_live_
STRIPE_SECRET_KEY=

# [PRODUCTION] Stripe Webhook Secret，用于验证 webhook 签名
# 本地用 `stripe listen --forward-to localhost:3000/api/webhooks/stripe` 获取
# 生产在 https://dashboard.stripe.com/webhooks 创建 endpoint 后获取
STRIPE_WEBHOOK_SECRET=

# [PRODUCTION] Stripe 价格 ID，从 https://dashboard.stripe.com/products 创建后获取
# 客户端可见，必须以 NEXT_PUBLIC_ 前缀
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_BUSINESS_PRICE_ID=

# ── App URL ────────────────────────────────────────────────────────────

# [PRODUCTION] 应用公开访问 URL，用于 Stripe Checkout 回调等
# Vercel 示例: https://shanxiang.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Token Encryption ───────────────────────────────────────────────────

# [REQUIRED] AES-256-GCM 加密密钥，加密存储在 DB 中的平台 OAuth Token
# 用 `openssl rand -hex 32` 生成，必须为 64 个十六进制字符
TOKEN_ENCRYPTION_KEY=

# ── S3 / Object Storage (Product Image Uploads) ────────────────────────

# [Optional] S3 兼容存储配置。不设置则使用 AWS 默认凭证链。
# 推荐: Cloudflare R2（零出网费）、AWS S3、或 MinIO（私有部署）
# S3_REGION=auto
# S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=uploads
# S3_UPLOAD_PREFIX=products/
# S3_PUBLIC_URL=

# ── Platform Integrations ──────────────────────────────────────────────

# [Optional] Shopify OAuth 凭证，从 Shopify Partner Dashboard 获取
# 用于发布商品图到 Shopify 商店
# SHOPIFY_CLIENT_ID=
# SHOPIFY_CLIENT_SECRET=

# ── FFmpeg (Video Pipeline — Phase 2) ──────────────────────────────────

# [Optional] 自定义 FFmpeg 路径，默认使用系统 PATH 中的 "ffmpeg"
# FFMPEG_PATH=ffmpeg
