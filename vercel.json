{
  "buildCommand": "npx prisma generate && next build",
  "installCommand": "npm ci",
  "framework": "nextjs",
  "env": {
    "DATABASE_URL": "@supabase-pooler-url",
    "DIRECT_URL": "@supabase-pooler-url",
    "AUTH_SECRET": "@generate-with-openssl-rand-hex-32",
    "NEXTAUTH_URL": "https://your-project.vercel.app",
    "GOOGLE_CLIENT_ID": "@google-oauth-client-id",
    "GOOGLE_CLIENT_SECRET": "@google-oauth-client-secret",
    "REPLICATE_API_KEY": "@replicate-api-key",
    "OPENAI_API_KEY": "@openai-api-key",
    "STRIPE_SECRET_KEY": "@stripe-secret-key",
    "STRIPE_WEBHOOK_SECRET": "@stripe-webhook-secret",
    "NEXT_PUBLIC_STRIPE_PRO_PRICE_ID": "@stripe-pro-price-id",
    "NEXT_PUBLIC_STRIPE_BUSINESS_PRICE_ID": "@stripe-business-price-id",
    "NEXT_PUBLIC_APP_URL": "https://your-project.vercel.app",
    "TOKEN_ENCRYPTION_KEY": "@generate-with-openssl-rand-hex-32",
    "S3_ENDPOINT": "https://your-account.r2.cloudflarestorage.com",
    "S3_ACCESS_KEY_ID": "@r2-access-key-id",
    "S3_SECRET_ACCESS_KEY": "@r2-secret-access-key",
    "S3_BUCKET": "shanxiang",
    "S3_UPLOAD_PREFIX": "products/",
    "S3_PUBLIC_URL": "https://your-bucket.r2.cloudflarestorage.com",
    "FFMPEG_ENABLED": "false"
  }
}
