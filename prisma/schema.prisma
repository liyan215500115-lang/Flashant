generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Auth ──────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  role          String       @default("user")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  accounts            Account[]
  imageProjects       ImageProject[]
  platformConnections PlatformConnection[]
  subscription        Subscription?
  brandPresets        BrandPreset[]
}

// ── Image Pipeline ────────────────────────────────────────────────────

model ImageProject {
  id               String        @id @default(cuid())
  userId           String
  title            String        @default("")
  promptTemplateId String?
  brandPresetId    String?
  status           ProjectStatus @default(DRAFT)
  errorMessage     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptTemplate  PromptTemplate? @relation(fields: [promptTemplateId], references: [id])
  brandPreset     BrandPreset?    @relation(fields: [brandPresetId], references: [id])
  productImages   ProductImage[]
  generatedImages GeneratedImage[]
  publishRecords  PublishRecord[]
  tasks           Task[]
}

model ProductImage {
  id             String   @id @default(cuid())
  imageProjectId String
  originalUrl    String
  thumbnailUrl   String?
  s3Key          String
  fileName       String
  fileSize       Int
  mimeType       String
  width          Int?
  height         Int?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  project          ImageProject    @relation(fields: [imageProjectId], references: [id], onDelete: Cascade)
  generatedImages  GeneratedImage[]
  tasks            Task[]
}

model GeneratedImage {
  id              String           @id @default(cuid())
  imageProjectId  String
  productImageId  String?
  s3Key           String
  url             String
  thumbnailUrl    String?
  promptUsed      String?
  aiProvider      String?          @default("replicate")
  modelVersion    String?
  generationMeta  Json?
  fileSize        Int?
  mimeType        String?
  width           Int?
  height          Int?
  status          GenerationStatus @default(PENDING)
  errorMessage    String?
  webhookId       String?
  createdAt       DateTime         @default(now())
  completedAt     DateTime?

  project       ImageProject @relation(fields: [imageProjectId], references: [id], onDelete: Cascade)
  productImage  ProductImage? @relation(fields: [productImageId], references: [id])

  publishRecords PublishRecord[]
}

// ── Platform Connections ──────────────────────────────────────────────

model PlatformConnection {
  id                     String   @id @default(cuid())
  userId                 String
  platform               Platform
  accessTokenEncrypted   String
  refreshTokenEncrypted  String?
  tokenExpiresAt         DateTime?
  scope                  String?
  platformUserId         String?
  platformStoreName      String?
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
}

// ── Publishing ────────────────────────────────────────────────────────

model PublishRecord {
  id               String        @id @default(cuid())
  imageProjectId   String
  generatedImageId String?
  platform         Platform
  status           PublishStatus @default(QUEUED)
  platformPostId   String?
  platformPostUrl  String?
  errorMessage     String?
  publishedAt      DateTime?
  createdAt        DateTime      @default(now())

  project        ImageProject    @relation(fields: [imageProjectId], references: [id], onDelete: Cascade)
  generatedImage GeneratedImage? @relation(fields: [generatedImageId], references: [id])
}

// ── Billing ───────────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  planTier             PlanTier           @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Brand Presets ─────────────────────────────────────────────────────

model BrandPreset {
  id        String   @id @default(cuid())
  userId    String
  name      String
  logoUrl   String?
  colors    Json?
  fonts     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageProjects ImageProject[]
}

// ── Prompt Templates ──────────────────────────────────────────────────

model PromptTemplate {
  id            String   @id @default(cuid())
  name          String
  nameZh        String?
  description   String?
  descriptionZh String?
  category      String   @default("general")
  prompt        String
  previewUrl    String?
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  imageProjects ImageProject[]
  tasks          Task[]
}

// ── Generation Tasks ──────────────────────────────────────────────────

model Task {
  id             String           @id @default(cuid())
  imageProjectId String
  productImageId String
  promptTemplateId String?
  predictionId   String?
  status         GenerationStatus @default(PENDING)
  errorMessage   String?
  resultUrl      String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  project       ImageProject    @relation(fields: [imageProjectId], references: [id], onDelete: Cascade)
  productImage  ProductImage    @relation(fields: [productImageId], references: [id])
  promptTemplate PromptTemplate? @relation(fields: [promptTemplateId], references: [id])
}

// ── Enums ─────────────────────────────────────────────────────────────

enum ProjectStatus {
  DRAFT
  GENERATING
  GENERATED
  REVIEW
  APPROVED
  PUBLISHING
  PUBLISHED
  FAILED
}

enum GenerationStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

enum Platform {
  SHOPIFY
  TIKTOK_SHOP
  ETSY
  MERCADO_LIBRE
}

enum PublishStatus {
  QUEUED
  UPLOADING
  PROCESSING
  PUBLISHED
  FAILED
}

enum PlanTier {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  UNPAID
}
